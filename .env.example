# ── LLM Selection (set ONE — Ollama requires no API key) ──────────────────────

# Option A: Local (FREE, no internet) — Ollama + qwen3.5:9b
# Requires: ollama installed + model pulled: ollama pull qwen3.5:9b
# Fits in 8 GB VRAM (RTX 4060 / 3070 Ti etc.) with Q4 quantisation
OLLAMA_MODEL=qwen3.5:9b
# OLLAMA_HOST=http://localhost:11434   # default, change if Ollama runs elsewhere

# Option B: Claude (Anthropic) — best quality for code generation
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Option C: Gemini 2.5 Pro (Google)
# GOOGLE_API_KEY=AIzaSy-your-key-here

# Option D: GPT-4o (OpenAI)
# OPENAI_API_KEY=sk-your-key-here

# ── PDK Paths (auto-detected if using volare) ─────────────────────────────────
# PDK_ROOT=/home/user/pdks
# SKY130_PDK=$PDK_ROOT/sky130A
# GF180_PDK=$PDK_ROOT/gf180mcuD

# ── Output directories ────────────────────────────────────────────────────────
GELOCHIP_OUTPUT_DIR=/tmp/gelochip_output

# ── Chainlit ──────────────────────────────────────────────────────────────────
# CHAINLIT_AUTH_SECRET=your-secret-here   # set for production deployments

# ── ArXiv / Search ────────────────────────────────────────────────────────────
# ARXIV_MAX_RESULTS=5

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_LEVEL=INFO
